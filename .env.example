# ─────────────────────────────────────────
# Governor Environment Configuration
# ─────────────────────────────────────────

# API Server
NODE_ENV=production
API_PORT=4000
API_HOST=0.0.0.0
DATABASE_URL=postgresql://user:password@host:5432/governor
# REDIS_URL=redis://host:6379  # Optional — omit for in-memory rate limiting
CORS_ORIGIN=https://agentgovernor.vercel.app

# Authentication (Clerk or Supabase)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Console
NEXT_PUBLIC_API_BASE_URL=https://api.governor.run

# SDK / CLI
# GOVERNOR_API_URL=https://api.governor.run

# ─────────────────────────────────────────
# Local Development (override above)
# ─────────────────────────────────────────
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/governor?schema=public
# REDIS_URL=redis://localhost:6379
# CORS_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# GOVERNOR_ORG_ID=org_dev
